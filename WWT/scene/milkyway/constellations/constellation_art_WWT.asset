local constellationsCSV = asset.resource("constellation_data.csv")
local transforms = asset.require("scene/solarsystem/sun/transforms")
local constellations_helper = asset.require("util/constellations_helper")

local images = asset.resource({
  Name = "Constellation Images",
  Type = "HttpSynchronization",
  Identifier = "constellation_images",
  Version = 4
})

local data = asset.resource({
  Name = "Constellation Files",
  Type = "HttpSynchronization",
  Identifier = "digitaluniverse_constellations_data",
  Version = 1
})

--function that reads the file
local function createConstellations(baseIdentifier, guiPath, constellationfile)
  local genConstellations = {}
  -- define parsec to meters
  local PARSEC_CONSTANT = 3.0856776E16
  local distanceMultiplier = 3.2
  local baseScale = 1e17
  local lines = openspace.readCSVFile(openspace.absPath(constellationfile))
  
  for _, line in ipairs(lines) do
    local group = line[1]
    local abbreviation = line[2]
    local name = line[3]
    local x = tonumber(line[4])
    local y = tonumber(line[5])
    local z = tonumber(line[6])
    local scale = tonumber(line[7])
    local imageName = line[8]
    local rotX = tonumber(line[9])
    local rotY = tonumber(line[10])
    local rotZ = tonumber(line[11])
    local centerStar = line[12]
    local magVec = math.sqrt(x*x + y*y + z*z)
    local normx = x / magVec
    local normy = y / magVec
    local normz = z / magVec

    local foundName = constellations_helper.findFullName(abbreviation)
    if foundName ~= nil then
      name = foundName
    end

    -- Fixed undefined 'globe' variable by wrapping it in quotes
    group = (group == "" and "globe" or group)

    -- Dynamically build tags so we can perfectly isolate zodiac vs non-zodiac
    local tags = { 
      "image_constellation", 
      "constellation_art_" .. string.lower(group), 
      "daytime_hidden", 
      "constellation_marking" 
    }

    -- Apply an exclusion tag to everything that isn't a zodiac
    if string.lower(group) ~= "zodiac" then
      table.insert(tags, "constellation_art_non_zodiac")
    end

    local aconstellation = {
      Identifier = baseIdentifier .. "-" .. abbreviation,
      Parent = transforms.SolarSystemBarycenter.Identifier,
      Transform = {
        Translation = {
          Type = "StaticTranslation",
          Position = {
            normx * PARSEC_CONSTANT * distanceMultiplier,
            normy * PARSEC_CONSTANT * distanceMultiplier,
            normz * PARSEC_CONSTANT * distanceMultiplier
          }
        },
        Rotation = {
          Type = "StaticRotation",
          Rotation = { tonumber(rotX), tonumber(rotY), tonumber(rotZ) }
        }
      },
      Renderable = {
        Type = "RenderablePlaneImageLocal",
        Enabled = false,
        Size = tonumber(baseScale * scale * distanceMultiplier / 10),
        Origin = "Center",
        Billboard = false,
        LazyLoading = true,
        Texture = images .. imageName,
        BlendMode = "Additive",
        Opacity = 0.1,
        DimInAtmosphere = true
      },
      Tag = tags,
      GUI = {
        Name = name .. " Image",
        Path = "/Milky Way/Constellations/" .. guiPath,
        Description = name .. " Image"
      }
    }
    table.insert(genConstellations, aconstellation)
  end
  return genConstellations
end

local ShowArt = {
  Identifier = "os.constellation_art.ShowArt",
  Name = "Show all constellation art",
  Command = [[
    openspace.fadeIn("{image_constellation}")
  ]],
  Documentation = "Enables and fades up constellation art work",
  GuiPath = "/Constellations",
  IsLocal = false
}

local HideArt = {
  Identifier = "os.constellation_art.HideArt",
  Name = "Hide all constellation art",
  Command = [[
    openspace.fadeOut("{image_constellation}")
  ]],
  Documentation = "Fades out constellation artwork",
  GuiPath = "/Constellations",
  IsLocal = false
}

local ShowZodiacArt = {
  Identifier = "os.constellation_art.ShowZodiacArt",
  Name = "Show only zodiac art",
  Command = [[
    openspace.fadeOut("{constellation_art_non_zodiac}")
    openspace.fadeIn("{constellation_art_zodiac}")
  ]],
  Documentation = "Fades out non-zodiac art and ensures zodiac art is visible",
  GuiPath = "/Constellations",
  IsLocal = false
}

local HideZodiacArt = {
  Identifier = "os.constellation_art.HideZodiacArt",
  Name = "Hide zodiac art",
  Command = [[
    openspace.fadeOut("{constellation_art_zodiac}")
  ]],
  Documentation = "Fades down zodiac art work",
  GuiPath = "/Constellations",
  IsLocal = false
}


local nodes = {}

-- ===================================================================================================================

-- Generates a GUI action for every constellation in the CSV
local function createFocusActions(constellationfile)
  local actions = {}
  local lines = openspace.readCSVFile(openspace.absPath(constellationfile))
  
  for _, line in ipairs(lines) do
    local abbreviation = line[2]
    local name = line[3]
    
    local foundName = constellations_helper.findFullName(abbreviation)
    if foundName ~= nil then
      name = foundName
    end

    -- Builds a command string that fades out every other constellation explicitly
    local fadeOutOthersCommand = ""
    for _, otherLine in ipairs(lines) do
      local otherAbbr = otherLine[2]
      if otherAbbr ~= abbreviation then
        -- Fade out the other nodes quickly (1 second)
        fadeOutOthersCommand = fadeOutOthersCommand .. string.format('openspace.fadeOut("Scene.ImageConstellation-%s.Renderable", 1); ', otherAbbr)
      end
    end

   local action = {
      Identifier = "os.constellation.focus." .. abbreviation,
      Name = "Focus on " .. name,
      Command = string.format([[
        openspace.setPropertyValueSingle("NavigationHandler.OrbitalNavigator.IdleMotion.Apply", false)
        openspace.fadeOut("Scene.SunGlare.Renderable")

        
        openspace.fadeIn("Scene.Constellations.Renderable")
        %s
        openspace.fadeIn("Scene.ImageConstellation-%s.Renderable", 1)
        
        openspace.setPropertyValueSingle("NavigationHandler.OrbitalNavigator.Anchor", "SolarSystemBarycenter")
        openspace.setPropertyValueSingle("NavigationHandler.OrbitalNavigator.Aim", "ImageConstellation-%s")

        openspace.setPropertyValueSingle("NavigationHandler.OrbitalNavigator.RetargetAnchor", nil)
        openspace.setPropertyValueSingle("NavigationHandler.OrbitalNavigator.RetargetAim", nil)

        openspace.constellationFocusCounter = (openspace.constellationFocusCounter or 0) + 1
        local clearLogic = "if openspace.constellationFocusCounter == " .. openspace.constellationFocusCounter .. " then openspace.action.triggerAction('os.constellation.focus.Clear') end"
        openspace.scheduleScript(clearLogic, 15)
  

      ]], fadeOutOthersCommand, abbreviation, abbreviation),
      Documentation = "Turns on lines, isolates " .. name .. " art, and focuses the camera.",
      GuiPath = "/Constellations/Focus", 
      IsLocal = false
    }
    table.insert(actions, action)
  end
  return actions
end

-- Manual action to clear all constellations when done
local ClearConstellationFocus = {
  Identifier = "os.constellation.focus.Clear",
  Name = "Clear Focus (Turn Everything Off)",
  Command = [[
    openspace.fadeOut("Scene.Constellations.Renderable")
    openspace.fadeOut("{image_constellation}")
    openspace.setPropertyValueSingle("NavigationHandler.OrbitalNavigator.Aim", "")
    openspace.fadeIn("Scene.SunGlare.Renderable")
  ]],
  Documentation = "Turns off constellation lines and art, and clears the camera aim.",
  GuiPath = "/Constellations/Focus",
  IsLocal = false
}

local focusActions = {}

asset.onInitialize(function()
  local constellationsCSV = images .. "constellation_data.csv"

  -- Existing node generation
  nodes = createConstellations("ImageConstellation", "Constellation Art", constellationsCSV)
  for _, n in ipairs(nodes) do
    openspace.addSceneGraphNode(n)
  end

  -- NEW: Generate and register the focus actions
  focusActions = createFocusActions(constellationsCSV)
  for _, act in ipairs(focusActions) do
    openspace.action.registerAction(act)
  end
  openspace.action.registerAction(ClearConstellationFocus)

  -- Existing static actions
  openspace.action.registerAction(ShowArt)
  openspace.action.registerAction(HideArt)
  openspace.action.registerAction(ShowZodiacArt)
  openspace.action.registerAction(HideZodiacArt)
end)

asset.onDeinitialize(function()
  -- Existing node removal
  for _, n in ipairs(nodes) do
    openspace.removeSceneGraphNode(n.Identifier)
  end

  -- NEW: Remove the focus actions
  for _, act in ipairs(focusActions) do
    openspace.action.removeAction(act.Identifier)
  end
  openspace.action.removeAction(ClearConstellationFocus.Identifier)

  -- Existing static action removal
  openspace.action.removeAction(HideZodiacArt)
  openspace.action.removeAction(ShowZodiacArt)
  openspace.action.removeAction(HideArt)
  openspace.action.removeAction(ShowArt)
end)

asset.export("ShowArtAction", ShowArt.Identifier)
asset.export("HideArtAction", HideArt.Identifier)
asset.export("ShowZodiacArt", ShowZodiacArt.Identifier)
asset.export("HideZodiacArt", HideZodiacArt.Identifier)



asset.meta = {
  Name = "Constellation Images",
  Description = "Artistic images depicting the constellations",
  Author = "James Hedberg",
  URL = "http://jameshedberg.com",
  License = "CC-BY"
}
