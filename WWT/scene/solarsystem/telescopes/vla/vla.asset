local earthAsset = asset.require('scene/solarsystem/planets/earth/globe') -- was .../earth but got error, testing .../globe
local sunAsset = asset.require('scene/solarsystem/sun/sun')


  
local vla1 = {
	Identifier = "vla1",
	Parent = earthAsset.Earth.Identifier,
	--Note: Lat/Lon/Scale values comes from alignment with Esri World Imagery 2D layer
	Transform = {
		Translation = {
			Type = "GlobeTranslation",
			Globe = earthAsset.Earth.Identifier,
            Latitude = 34.083610, 
            Longitude = -107.618904,
            Altitude = 0,
			UseHeightmap = true
		},
		Rotation = {
			Type = "GlobeRotation",
			Globe = earthAsset.Earth.Identifier,
            Latitude = 34.083610, 
            Longitude = -107.618904,
			UseHeightmap = false
		}
		
	},
	Renderable = {
		Type = "RenderableModel",
		GeometryFile = asset.resource("vla.glb"),
		forceRenderInvisible = true,
		ModelScale = 1, --83000
		RotationVector = {00.00,00.00,00.00}, -- {0.000000,271.130000,270.000000}
		LightSources = { sunAsset.LightSource }
	},
	GUI = {
		Name = "VLA A1",
		Path = "/Solar System/Telescopes/Very Large Array",
		Description = [[
			The Very Large Array is a centimeter-wavelength radio astronomy observatory located in Magdalena, New Mexico. 
		]],
	}
}

