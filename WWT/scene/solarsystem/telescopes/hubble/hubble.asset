local sunTransforms = asset.require('scene/solarsystem/sun/transforms')
local transforms = asset.require('scene/solarsystem/planets/earth/transforms')
local sun = asset.require("scene/solarsystem/sun/sun")
local model = asset.resource("data/hubble.fbx")
local coreKernels = asset.require("spice/core")

local omm = asset.resource({
  Name = "Satellite OMM Data (HST)",
  Type = "UrlSynchronization",
  Identifier = "satellite_omm_data_hst",
  Url = "http://www.celestrak.com/NORAD/elements/gp.php?CATNR=20580&FORMAT=kvn",
  Filename = "HST.txt",
  SecondsUntilResync = openspace.time.secondsPerDay()
})



  
  local hubble = {
     Identifier = "HST",
      Parent = transforms.EarthInertial.Identifier,
    BoundingSphere = 15,
    Transform = {
      Translation = {
      Type = "GPTranslation",
      Observer = transforms.EarthInertial.Identifier,
      File = omm .. "HST.txt",
      Format = "OMM"
      },
      Rotation = {
          Type = "SpiceRotation",
          SourceFrame = "GALACTIC",
          DestinationFrame = "J2000",
      }
    },
    Renderable = {
    Type = "RenderableModel",
		Body = "HST",
		Enabled = true,
		GeometryFile = model,
		ModelScale = "Centimeter",
		 LightSources = {
		  {
			Type = "SceneGraphLightSource",
			Identifier = "Sun",
			Node = sunTransforms.SolarSystemBarycenter.Identifier,
			Intensity = 1.0
		  }
		 },
		AmbientIntensity = 0.1,
		DiffuseIntensity = 0.85,
		PerformShading = true,
    },
	
	GUI = {
			  Name = "Hubble",
			  Path = "/Telescopes/Hubble",
		  }
}

local hubbleTrail = {
    Identifier = "hubbleTrail",
    Parent = transforms.EarthInertial.Identifier,
    Renderable = {
        Type = "RenderableTrailOrbit",
        Translation = {
		  Type = "GPTranslation",
		  Observer = transforms.EarthInertial.Identifier,
		  File = omm .. "HST.txt",
		  Format = "OMM"
        },
		RenderBinMode = "PostDeferredTransparent",
        Color = { 1.0, 0.6, 0.2},
        Fade = 1.5,
        Period = 5707.7112915644553642826632082587,
        Resolution = 320
      },
    Tag = { "earth_satellite", "hubble" },
    GUI = {
        Name = "Hubble Trail",
        Path = "/Solar System/Telescopes/Hubble"
    }
}


asset.onInitialize(function()
  local i = openspace.space.readKeplerFile(omm .. "HST.txt", "OMM")
  hubbleTrail.Renderable.Period = i[1].Period / (60 * 60 * 24)

  openspace.addSceneGraphNode(hubble)
  openspace.addSceneGraphNode(hubbleTrail)
end)

asset.onDeinitialize(function()
  openspace.removeSceneGraphNode(hubble)
  openspace.removeSceneGraphNode(hubbleTrail)
end)

asset.export(hubble)
asset.export(hubbleTrail)
  

asset.meta = {
    Name = "Hubble Space Telescope",
    Version = "1.0",
    Description = [[ Model and Trail for Hubble Space Telescope, model by Dan Tell, trail from
    JPL Horizons]],
    Author = "Dan Tell",
    URL = "www.calacademy.org",
    License = "CC-BY"
}